{
  "name": "konstant",
  "version": "3.6.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build && pnpm ci:output",
    "check-types": "turbo run check-types",
    "ci:clean": "tsx tools/scripts/clean-install",
    "ci:output": "tsx tools/scripts/create-output",
    "ci:sync:deps": "tsx tools/scripts/sync-deps.js ",
    "ci:sync:publish": "tsx tools/scripts/sync-publish-package.js && pnpm sort-packages",
    "ci:tag": "tsx tools/scripts/tag-release.ts",
    "ci:version": "tsx tools/scripts/version",
    "ci:version:major": "pnpm ci:version major && pnpm ci:sync:publish",
    "ci:version:minor": "pnpm ci:version minor && pnpm ci:sync:publish",
    "ci:version:patch": "pnpm ci:version patch && pnpm ci:sync:publish",
    "dev": "turbo run dev --filter=web",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "sort-packages": "tsx tools/scripts/sort-all-package-jsons.ts"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@repo/eslint-config": "workspace:*",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.8.0",
    "@swc/helpers": "^0.5.19",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "25.5.0",
    "@types/semver": "^7.7.1",
    "copyfiles": "^2.4.1",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.4",
    "prettier": "^3.8.1",
    "rimraf": "6.1.3",
    "semver": "^7.7.4",
    "sort-package-json": "^3.6.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript": "5.9.3",
    "url": "^0.11.4"
  },
  "packageManager": "pnpm@10.2.1",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
